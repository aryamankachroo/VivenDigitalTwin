OPENAI_API_KEY=your_openai_key_here
SECRET_KEY=your_flask_secret_key_here
FLASK_ENV=development
# How many newest inbox messages to pull into the vector index each sync (default 50)
# SYNC_EMAIL_LIMIT=50
# Optional: allow OAuth token exchange over http://localhost (dev only; auto-set in code when FLASK_ENV=development)
# OAUTHLIB_INSECURE_TRANSPORT=1
